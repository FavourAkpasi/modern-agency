# Copy this file to `.env.local` and fill in real values.

# Public GraphQL endpoint used by the projects service (browser-accessible).
NEXT_PUBLIC_API_URL=https://graphqlzero.almansi.me/api

# Sentry error tracking.
# DSN is public (client-side)
NEXT_PUBLIC_SENTRY_DSN=
# Used only at build time for source-map upload. SENTRY_AUTH_TOKEN is a SECRET 
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=